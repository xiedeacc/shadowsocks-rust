{
  // Windows TUN deployment template. Comments are accepted because
  // shadowsocks-rust parses configs with json5.
  //
  // Why DNS is on port 53:
  //   The deploy script points Windows' DNS client at 127.0.0.1, and the
  //   Windows DNS client API does not allow a custom port. So the local
  //   DNS server MUST bind 53 - moving it to 1053 silently breaks Chrome.
  //   The deploy script checks for port-53 conflicts (Hyper-V vSwitch,
  //   Internet Connection Sharing, DNS Server role) and warns up front.

  // no_delay / fast_open are PROCESS-WIDE flags. They MUST be at the
  // top level: SSServerExtConfig (servers[]) does not declare these
  // fields, so putting them inside a server entry is silently dropped
  // by serde and has no effect. At the top level the same flags apply
  // to BOTH:
  //   * accept_opts on every locals[] listener (socks/http/dns/tun)
  //     -> TCP_NODELAY on incoming proxy connections + TCP_FASTOPEN
  //        cookies served from the listener
  //   * connect_opts on every outbound connection to servers[]
  //     -> TCP_NODELAY + client-side TCP_FASTOPEN on the sslocal
  //        upstream socket to the SS server (saves ~1 RTT after the
  //        kernel TFO cookie is warm)
  "no_delay": true,
  "fast_open": true,

  "locals": [
    {
      "local_address": "127.0.0.1",
      "local_port": 1080,
      "protocol": "socks"
    },
    {
      "local_address": "127.0.0.1",
      "local_port": 1081,
      "protocol": "http"
    },
    {
      // Local DNS responder (IPv4 loopback). Bound to loopback so the
      // listener is not exposed to the LAN; Chrome reaches it through
      // the OS resolver because the deploy script sets the physical
      // adapter DNS to 127.0.0.1.
      "local_address": "127.0.0.1",
      "local_port": 53,
      "protocol": "dns",
      "mode": "tcp_and_udp",
      "local_dns_address": "223.5.5.5",
      "local_dns_port": 53,
      "remote_dns_address": "8.8.8.8",
      "remote_dns_port": 53,
      "client_cache_size": 64
    },
    {
      // Local DNS responder (IPv6 loopback). MUST exist alongside the
      // 127.0.0.1 listener: the deploy script forces every active
      // interface's IPv6 DNS to ::1 (home routers commonly advertise
      // themselves via SLAAC/RDNSS, which Windows races in parallel
      // with IPv4 DNS), so AAAA queries land on this socket.
      "local_address": "::1",
      "local_port": 53,
      "protocol": "dns",
      "mode": "tcp_and_udp",
      "local_dns_address": "223.5.5.5",
      "local_dns_port": 53,
      "remote_dns_address": "8.8.8.8",
      "remote_dns_port": 53,
      "client_cache_size": 64
    },
    {
      // Windows TUN device. Every outbound packet ends up here via the
      // catch-all 0.0.0.0/1 + 128.0.0.0/1 routes the deploy script
      // installs; sslocal then makes per-connection direct/proxy
      // decisions based on the runtime bypass_ip / direct_ip sets.
      "protocol": "tun",
      "mode": "tcp_and_udp",
      "tun_interface_name": "shadowsocks-tun",
      "tun_interface_address": "10.255.0.1/24",
      "tun_interface_destination": "10.255.0.2/24"
    }
  ],
  "route_rules": {
    "dns_cache_capacity": 10000,
    "dns_cache_refresh_batch_size": 500,
    "dns_cache_refresh_enabled": true,
    "dns_cache_ttl_seconds": 604800,
    // dns_intercept_mode=tun means: trust the TUN catch-all + local DNS
    // listener to intercept DNS, no firewall rules required (Windows
    // does not have nftables).
    //
    // Upstream resolvers and the listen socket are read directly from
    // `locals[].dns` above.
    "dns_intercept_mode": "tun",
    // Strip AAAA from DNS responses. Set false ONLY if the host
    // has working public IPv6 -- otherwise browsers spend happy-
    // eyeballs time on v6 attempts that never connect before
    // falling back to v4.
    "dns_ipv4_only": true,
    "geoip_sources": [
      "https://github.com/Loyalsoldier/v2ray-rules-dat/releases/latest/download/geoip.dat"
    ],
    "bypass_domain_sources": [
      "https://raw.githubusercontent.com/Loyalsoldier/v2ray-rules-dat/release/gfw.txt"
    ]
  },
  "servers": [
    {
      "server": "127.0.0.1",
      "server_port": 8388,
      "password": "change-me",
      "timeout": 300,
      "method": "aes-256-gcm",
      // NOTE: fast_open / no_delay live at the TOP level of the config,
      // not here — see the comment block at the top of the file.
      // plugin_opts "mux=8;fast-open":
      //   * mux=8 lets the xray-plugin client multiplex up to 8 outbound
      //     TCP/UDP streams over a single WebSocket. Without it every
      //     new browser request pays a TLS+WS handshake; with mux=8 the
      //     handshake amortises across all in-flight connections and
      //     browsing latency drops sharply once the tunnel is warm.
      //   * fast-open: TFO on the *inner* connection xray-plugin opens
      //     to the local ssserver, mirroring the outer setting above.
      "plugin": "D:\\software\\shadowsocks\\bin\\xray-plugin.exe",
      "plugin_opts": "tls;host=forsimple.youkechat.net;path=/sspath;mux=8;fast-open"
    }
  ],
  "web_admin": {
    "listen": "127.0.0.1:9090"
  }
}
